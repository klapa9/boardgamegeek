generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id           String   @id @default(cuid())
  title        String
  adminToken   String   @unique @default(cuid())
  organizerUserProfileId String?
  chosenDay    String?
  chosenGameId String?
  locked       Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  organizer      UserProfile? @relation("OrganizerSessions", fields: [organizerUserProfileId], references: [id], onDelete: SetNull)
  players        Player[]
  games          Game[]       @relation("SessionGames")
  chosenGame     Game?        @relation("SessionChosenGame", fields: [chosenGameId], references: [id], onDelete: SetNull)
  availability   Availability[]
  ratings        Rating[]
  dateOptions    SessionDateOption[]

  @@index([organizerUserProfileId])
}

model SessionDateOption {
  id        String   @id @default(cuid())
  sessionId String
  date      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, date])
  @@index([sessionId])
}

model Player {
  id        String   @id @default(cuid())
  sessionId String
  userProfileId String?
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session      Session      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userProfile  UserProfile? @relation(fields: [userProfileId], references: [id], onDelete: SetNull)
  availability Availability[]
  ratings      Rating[]
  gamesAdded   Game[]       @relation("GameAddedBy")

  @@index([sessionId])
  @@index([userProfileId])
  @@unique([sessionId, userProfileId])
}

model Game {
  id               String   @id @default(cuid())
  sessionId        String
  title            String
  bggId            Int?
  yearPublished    Int?
  thumbnailUrl     String?
  imageUrl         String?
  minPlayers       Int?
  maxPlayers       Int?
  playingTime      Int?
  minAge           Int?
  bggRating        Float?
  bggBayesRating   Float?
  bggWeight        Float?
  mechanics        String[] @default([])
  categories       String[] @default([])
  designers        String[] @default([])
  playMode         String?
  communityPlayers Int[]    @default([])
  playerCountPoll  Json?
  ranks            Json?
  lastSyncedAt     DateTime?
  addedBy          String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  session           Session   @relation("SessionGames", fields: [sessionId], references: [id], onDelete: Cascade)
  chosenForSessions Session[] @relation("SessionChosenGame")
  addedByPlayer     Player?   @relation("GameAddedBy", fields: [addedBy], references: [id], onDelete: SetNull)
  ratings           Rating[]

  @@index([sessionId])
}

model Availability {
  id        String  @id @default(cuid())
  sessionId String
  playerId  String
  day       String
  available Boolean @default(false)

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  player  Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, day])
  @@index([sessionId])
}

model Rating {
  id        String @id @default(cuid())
  sessionId String
  playerId  String
  gameId    String
  score     Int

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  player  Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  game    Game    @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([playerId, gameId])
  @@index([sessionId])
}

model CollectionGame {
  id               String   @id @default(cuid())
  bggId            Int?     @unique
  title            String
  yearPublished    Int?
  thumbnailUrl     String?
  imageUrl         String?
  minPlayers       Int?
  maxPlayers       Int?
  playingTime      Int?
  minAge           Int?
  bggRating        Float?
  bggBayesRating   Float?
  bggWeight        Float?
  designers        String[] @default([])
  playMode         String?
  communityPlayers Int[]    @default([])
  playerCountPoll  Json?
  ranks            Json?
  hidden           Boolean  @default(false)
  source           String   @default("manual")
  lastSyncedAt     DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  mechanics  CollectionGameMechanic[]
  categories CollectionGameCategory[]
  groups     CollectionGroupGame[]

  @@index([title])
  @@index([hidden])
  @@index([source])
  @@index([lastSyncedAt])
}

model CollectionSyncState {
  id             String   @id @default("default")
  bggUsername    String?
  lastSyncedAt   DateTime?
  lastStatus     String?
  syncInProgress Boolean  @default(false)
  syncStartedAt  DateTime?
  syncFinishedAt DateTime?
  totalGames     Int      @default(0)
  processedGames Int      @default(0)
  updatedAt      DateTime @updatedAt
}

model UserProfile {
  id          String   @id @default(cuid())
  clerkUserId String   @unique
  displayName String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  players           Player[]
  organizedSessions Session[] @relation("OrganizerSessions")
}

model CollectionGroup {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  games CollectionGroupGame[]

  @@index([name])
}

model CollectionGroupGame {
  groupId           String
  collectionGameId  String
  createdAt         DateTime @default(now())

  group          CollectionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  collectionGame CollectionGame  @relation(fields: [collectionGameId], references: [id], onDelete: Cascade)

  @@id([groupId, collectionGameId])
  @@index([collectionGameId])
}

model Mechanic {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  collectionGames CollectionGameMechanic[]
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  collectionGames CollectionGameCategory[]
}

model CollectionGameMechanic {
  collectionGameId String
  mechanicId       String

  collectionGame CollectionGame @relation(fields: [collectionGameId], references: [id], onDelete: Cascade)
  mechanic       Mechanic       @relation(fields: [mechanicId], references: [id], onDelete: Cascade)

  @@id([collectionGameId, mechanicId])
  @@index([mechanicId])
}

model CollectionGameCategory {
  collectionGameId String
  categoryId       String

  collectionGame CollectionGame @relation(fields: [collectionGameId], references: [id], onDelete: Cascade)
  category       Category       @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([collectionGameId, categoryId])
  @@index([categoryId])
}

